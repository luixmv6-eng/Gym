# Copia este archivo a .env y rellena tus claves.
# La app funciona SIN estas claves (modo offline con datos locales).
# Se activan cuando las agregas.

# (a) Supabase - auth real (email + Google) y sincronización en la nube.
#     1. Crea proyecto en https://supabase.com/
#     2. Ejecuta supabase/schema.sql en el SQL Editor
#     3. Pega Project URL y anon key aquí
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# (b) Coach IA - elige UN proveedor (prioridad: NVIDIA > Mistral).
#     Sin ninguna clave, el coach responde en modo offline con FAQ.
#
#   Opción recomendada: NVIDIA NIM (modelos 70B gratis) - https://build.nvidia.com/
#     La clave empieza por "nvapi-". Es OpenAI-compatible.
VITE_NVIDIA_API_KEY=
#
#   Alternativa: Mistral - https://console.mistral.ai/
VITE_MISTRAL_API_KEY=
#
#   (Opcional) forzar un modelo concreto. Ejemplos:
#     NVIDIA:  meta/llama-3.3-70b-instruct  |  nvidia/llama-3.1-nemotron-70b-instruct
#     Mistral: mistral-small-latest  |  mistral-medium-latest
VITE_AI_MODEL=

# (c) ExerciseDB (GIFs animados de ejercicios) vía RapidAPI
#     https://rapidapi.com/justin-WFnsXH_haHLw/api/exercisedb
#     Sin clave, se muestra un placeholder por grupo muscular.
VITE_RAPIDAPI_KEY=
