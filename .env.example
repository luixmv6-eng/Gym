# Copia este archivo a .env y rellena tus claves.
# La app funciona SIN estas claves (modo offline con datos locales).

# (a) Supabase - auth real (email + Google) y sincronización en la nube.
#     1. Crea proyecto en https://supabase.com/
#     2. Ejecuta supabase/schema.sql en el SQL Editor
#     3. Pega Project URL y anon key aquí (URL base, SIN /rest/v1/)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# (b) Coach IA = Mistral - https://console.mistral.ai/
#     Router por complejidad: simple -> mistral-small, compleja -> mistral-large.
VITE_MISTRAL_API_KEY=
#   (Opcional) forzar un modelo concreto (desactiva el router):
VITE_AI_MODEL=
#   (Opcional) proxy para usar NVIDIA Llama 70B en preguntas complejas sin
#   exponer la clave (NVIDIA bloquea CORS directo desde el navegador).
#   Despliega supabase/functions/ai-proxy y pega su URL:
VITE_AI_PROXY_URL=

# (c) ExerciseDB (GIFs animados de ejercicios) vía RapidAPI
#     https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
VITE_RAPIDAPI_KEY=

# (d) USDA FoodData Central - búsqueda mundial de alimentos.
#     Sin clave usa DEMO_KEY (límite bajo). Gratis en:
#     https://fdc.nal.usda.gov/api-key-signup.html
VITE_USDA_API_KEY=
